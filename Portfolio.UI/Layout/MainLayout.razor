@inherits LayoutComponentBase

<div class="page-wrapper">
    <nav class="navbar navbar-expand-lg glass-nav fixed-top py-3">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2 text-decoration-none" href="/">
                <img src="images/logo.png" alt="EH Logo" style="height: 46px; width: auto; mix-blend-mode: multiply; filter: contrast(1.1) brightness(1.05); transition: transform 0.3s ease;" class="hover-scale" />
                <div class="logo-text-container d-flex flex-column lh-1 ms-1">
                    <span class="fw-bold fs-5" style="letter-spacing: -0.5px; color: var(--text-primary);">Emre Haksever</span>
                    <span class="fw-medium mt-1" style="font-size: 0.7rem; letter-spacing: 1.5px; color: var(--accent-primary); text-transform: uppercase;">Computer Engineer</span>
                </div>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <i class="bi bi-list  fs-2"></i>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto gap-2">
                    <li class="nav-item">
                        <NavLink class="nav-link " href="/" Match="NavLinkMatch.All">Anasayfa</NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link " href="/projects">Projeler</NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link " href="/skills">Yetenekler</NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link " href="/experiences">Deneyimler</NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link " href="/contact">İletişim</NavLink>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="content-wrapper" style="padding-top: 100px; padding-bottom: 60px; min-height: calc(100vh - 160px);">
        @Body
    </main>

@using Portfolio.UI.Models
@using Portfolio.UI.Services
@inject ProfileService ProfileService

    <footer class="py-4 text-center" style="border-top: 1px solid var(--glass-border); background: var(--bg-secondary);">
        <div class="container">
            <div class="d-flex justify-content-center gap-3 mb-3">
                @if (profile != null)
                {
                    <a href="@(profile.GithubUrl?.StartsWith("http") == true ? profile.GithubUrl : $"https://{profile.GithubUrl}")" target="_blank" class="text-dark fs-4 hover-card"><i class="bi bi-github"></i></a>
                    <a href="@(profile.LinkedInUrl?.StartsWith("http") == true ? profile.LinkedInUrl : $"https://{profile.LinkedInUrl}")" target="_blank" class="text-primary fs-4 hover-card"><i class="bi bi-linkedin"></i></a>
                }
            </div>
            <p class="text-secondary mb-0">&copy; @DateTime.Now.Year Emre Haksever. Tüm Hakları Saklıdır.</p>
        </div>
    </footer>
</div>

@code {
    private ProfileInfoDto profile;

    protected override async Task OnInitializedAsync()
    {
        profile = await ProfileService.GetProfileAsync();
    }
}
