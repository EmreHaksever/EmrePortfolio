@page "/admin"
@attribute [Authorize]
@using Portfolio.UI.Services
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-success">Admin Paneli</h2>
        <button class="btn btn-outline-danger" @onclick="HandleLogout">
            <i class="bi bi-box-arrow-right"></i> Çıkış Yap
        </button>
    </div>

    <div class="row">
        <div class="col-md-12 text-center">
            <p class="lead">Buradan projelerini, deneyimlerini ve yeteneklerini yönetebilirsin.</p>
            <hr />
        </div>
    </div>

    <div class="row mt-4">

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm border-primary h-100">
                <div class="card-body text-center d-flex flex-column">
                    <h5 class="card-title text-primary">Projeler</h5>
                    <p class="card-text flex-grow-1">Portfolyondaki projeleri ekle, sil veya güncelle.</p>
                    <button class="btn btn-primary mt-auto" @onclick="GoToProjects">Projeleri Yönet</button>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm border-success h-100">
                <div class="card-body text-center d-flex flex-column">
                    <h5 class="card-title text-success">Deneyimler</h5>
                    <p class="card-text flex-grow-1">Geçmiş iş, staj ve girişim tecrübelerini buradan yönet.</p>
                    <button class="btn btn-success mt-auto" @onclick="GoToExperiences">Deneyim Yönetimi</button>
                </div>
            </div>
        </div>

    </div>
</div>

@code {
    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        NavigationManager.NavigateTo("/login");
    }

    private void GoToProjects()
    {
        NavigationManager.NavigateTo("/admin/projects");
    }

    private void GoToExperiences()
    {
        NavigationManager.NavigateTo("/admin/experiences");
    }
}