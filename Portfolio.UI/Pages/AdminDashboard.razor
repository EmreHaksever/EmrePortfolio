@page "/admin"
@attribute [Authorize]
@using Portfolio.UI.Services
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-success">Admin Paneli</h2>
        <button class="btn btn-outline-danger" @onclick="HandleLogout">
            <i class="bi bi-box-arrow-right"></i> Çıkış Yap
        </button>
    </div>

    <div class="row">
        <div class="col-md-12 text-center">
            <p class="lead">Buradan projelerini, deneyimlerini ve yeteneklerini yönetebilirsin.</p>
            <hr />
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-primary">
                <div class="card-body text-center">
                    <h5 class="card-title text-primary">Projeler</h5>
                    <p class="card-text">Portfolyondaki projeleri ekle, sil veya güncelle.</p>
                    <button class="btn btn-primary" @onclick='() => NavigationManager.NavigateTo("/admin/projects")'>Projeleri Yönet</button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        NavigationManager.NavigateTo("/login");
    }
}