@page "/experiences"
@using Portfolio.UI.Models
@using Portfolio.UI.Services
@inject ExperienceService ExperienceService

<div class="container py-5">
    <div class="text-center mb-5">
        <h2 class="display-5 fw-bold  mb-3">Deneyimlerim</h2>
        <p class="lead text-secondary mx-auto" style="max-width: 600px;">
            Kariyer yolculuğum, stajlarım ve görev aldığım organizasyonlar.
        </p>
    </div>

    @if (experiences == null)
    {
        <div class="d-flex justify-content-center align-items-center" style="height: 30vh;">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    else if (!experiences.Any())
    {
        <div class="alert alert-info glass-panel text-center " role="alert">
            Henüz eklenmiş bir deneyim bulunmuyor.
        </div>
    }
    else
    {
        <div class="row justify-content-center mt-5">
            <div class="col-lg-8">
                <div class="timeline">
                    @foreach (var exp in experiences)
                    {
                        <div class="timeline-item glass-panel p-4 hover-card">
                            <div class="timeline-dot"></div>
                            <div class="timeline-date">
                                <i class="bi bi-calendar3 me-2"></i> @exp.StartDate - @exp.EndDate
                            </div>
                            <h3 class="h4 fw-bold  mt-2">@exp.Title</h3>
                            <div class="d-flex align-items-center gap-3 mb-3 text-secondary">
                                <span><i class="bi bi-building me-1"></i> @exp.Company</span>
                                <span><i class="bi bi-geo-alt me-1"></i> @exp.Location</span>
                            </div>
                            <p class="text-secondary mb-0" style="white-space: pre-wrap; line-height: 1.6;">@exp.Description</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<ExperienceDto> experiences;
    protected override async Task OnInitializedAsync() => experiences = await ExperienceService.GetAllExperiencesAsync();
}
