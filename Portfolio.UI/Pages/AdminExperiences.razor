@page "/admin/experiences"
@attribute [Authorize]
@using Portfolio.UI.Models
@using Portfolio.UI.Services
@inject ExperienceService ExperienceService
@inject NavigationManager NavigationManager

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Deneyimler Yönetimi</h3>
        <button class="btn btn-success" @onclick='() => NavigationManager.NavigateTo("/admin/experiences/add")'>
            + Yeni Deneyim Ekle
        </button>
    </div>
    <hr />

    @if (experiences == null)
    {
        <p><em>Deneyimler yükleniyor...</em></p>
    }
    else if (!experiences.Any())
    {
        <div class="alert alert-info">Henüz hiç deneyim eklenmemiş.</div>
    }
    else
    {
        <table class="table table-striped table-hover mt-3 shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Pozisyon / Ünvan</th>
                    <th>Şirket</th>
                    <th>Başlangıç</th>
                    <th>Bitiş</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var exp in experiences)
                {
                    <tr>
                        <td><strong>@exp.Title</strong></td>
                        <td>@exp.Company</td>
                        <td>@exp.StartDate.ToString("MMM yyyy")</td>
                        <td>
                            @if (exp.IsCurrent)
                            {
                                <span class="badge bg-success">Devam Ediyor</span>
                            }
                            else
                            {
                                @exp.EndDate?.ToString("MMM yyyy")
                            }
                        </td>
                        <td>
                            <button class="btn btn-sm btn-warning" @onclick='() => NavigationManager.NavigateTo($"/admin/experiences/edit/{exp.Id}")'>Düzenle</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteExperience(exp.Id)">Sil</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<ExperienceDto> experiences;

    protected override async Task OnInitializedAsync()
    {
        await LoadExperiences();
    }

    private async Task LoadExperiences()
    {
        experiences = await ExperienceService.GetAllExperiencesAsync();
    }

    private async Task DeleteExperience(int id)
    {
        var isSuccess = await ExperienceService.DeleteExperienceAsync(id);
        if (isSuccess)
        {
            await LoadExperiences();
        }
    }
}