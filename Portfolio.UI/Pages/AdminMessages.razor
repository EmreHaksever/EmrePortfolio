@page "/admin/messages"
@attribute [Authorize]
@using Portfolio.UI.Models
@using Portfolio.UI.Services
@inject MessageService MessageService
@inject NavigationManager NavigationManager

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Gelen Mesajlar</h3>
        <button class="btn btn-outline-secondary" @onclick="LoadMessages">
            <i class="bi bi-arrow-clockwise"></i> Yenile
        </button>
    </div>
    <hr />

    @if (messages == null)
    {
        <p><em>Mesajlar yükleniyor...</em></p>
    }
    else if (!messages.Any())
    {
        <div class="alert alert-info">Henüz hiç mesajınız yok.</div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover align-middle mb-0 bg-white">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 20%;">Gönderen</th>
                        <th style="width: 20%;">E-Posta</th>
                        <th style="width: 15%;">Tarih</th>
                        <th style="width: 30%;">Konu</th>
                        <th style="width: 15%;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var msg in messages)
                    {
                        var rowClass = msg.IsRead ? "" : "table-primary fw-bold";
                        <tr class="@rowClass">
                            <td>@msg.FullName</td>
                            <td><a href="mailto:@msg.Email" class="text-decoration-none">@msg.Email</a></td>
                            <td>@msg.DateSent.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                <div class="text-truncate" style="max-width: 250px;">@msg.Subject</div>
                            </td>
                            <td>
                                @if (!msg.IsRead)
                                {
                                    <button class="btn btn-sm btn-success me-1" @onclick="() => MarkAsRead(msg.Id)" title="Okundu İşaretle">
                                        <i class="bi bi-check2-all"></i>
                                    </button>
                                }
                                <button class="btn btn-sm btn-primary me-1" @onclick="() => ShowMessageDetails(msg)" title="Oku">
                                    <i class="bi bi-eye"></i>
                                </button>
                                <button class="btn btn-sm btn-danger" @onclick="() => DeleteMessage(msg.Id)" title="Sil">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@* Mesaj Detay Modalı *@
@if (selectedMessage != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5); z-index: 1050;">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="bi bi-envelope-open me-2"></i>Mesaj Detayı</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h6 class="text-muted mb-1 text-uppercase" style="font-size: 0.8rem;">Gönderen</h6>
                            <p class="mb-0 fs-5 fw-medium">@selectedMessage.FullName</p>
                        </div>
                        <div class="col-md-6 text-md-end mt-3 mt-md-0">
                            <h6 class="text-muted mb-1 text-uppercase" style="font-size: 0.8rem;">İletişim & Tarih</h6>
                            <p class="mb-0"><a href="mailto:@selectedMessage.Email" class="text-decoration-none">@selectedMessage.Email</a></p>
                            <p class="text-muted small mb-0">@selectedMessage.DateSent.ToString("dd MMMM yyyy, HH:mm")</p>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <h6 class="text-muted mb-1 text-uppercase" style="font-size: 0.8rem;">Konu</h6>
                        <p class="mb-0 fs-5 fw-bold">@selectedMessage.Subject</p>
                    </div>
                    <hr class="text-muted opacity-25" />
                    <div class="mb-2">
                        <h6 class="text-muted mb-3 text-uppercase" style="font-size: 0.8rem;">Mesaj İçeriği</h6>
                        <div class="p-3 bg-light rounded border" style="white-space: pre-wrap; font-size: 1.05rem; line-height: 1.6;">@selectedMessage.Content</div>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Kapat</button>
                    <a href="mailto:@selectedMessage.Email?subject=RE: @selectedMessage.Subject" class="btn btn-primary">
                        <i class="bi bi-reply me-1"></i> E-Posta ile Yanıtla
                    </a>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<MessageDto> messages;
    private MessageDto selectedMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadMessages();
    }

    private async Task LoadMessages()
    {
        messages = await MessageService.GetAllMessagesAsync();
    }

    private async Task MarkAsRead(int id)
    {
        var isSuccess = await MessageService.MarkAsReadAsync(id);
        if (isSuccess)
        {
            await LoadMessages();
        }
    }

    private async Task ShowMessageDetails(MessageDto message)
    {
        selectedMessage = message;
        if (!message.IsRead)
        {
            await MarkAsRead(message.Id);
        }
    }

    private void CloseModal()
    {
        selectedMessage = null;
    }

    private async Task DeleteMessage(int id)
    {
        var isSuccess = await MessageService.DeleteMessageAsync(id);
        if (isSuccess)
        {
            if (selectedMessage?.Id == id) selectedMessage = null;
            await LoadMessages();
        }
    }
}
