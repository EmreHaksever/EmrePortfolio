@page "/admin/projects/edit/{Id:int}"
@attribute [Authorize]
@using Portfolio.UI.Models
@using Portfolio.UI.Services
@inject ProjectService ProjectService
@inject NavigationManager NavigationManager

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-warning">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">Projeyi Düzenle</h4>
                </div>
                <div class="card-body">
                    @if (updateProject == null)
                    {
                        <p><em>Proje bilgileri yükleniyor...</em></p>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label class="form-label">Proje Adı</label>
                            <input type="text" class="form-control" @bind="updateProject.Name" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Kısa Özet</label>
                            <input type="text" class="form-control" @bind="updateProject.Summary" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Teknik Detaylar</label>
                            <textarea class="form-control" rows="4" @bind="updateProject.TechnicalDetail"></textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Etiketler</label>
                            <input type="text" class="form-control" @bind="updateProject.Tags" />
                        </div>

                        <div class="d-flex justify-content-between">
                            <button class="btn btn-secondary" @onclick='() => NavigationManager.NavigateTo("/admin/projects")'>İptal</button>
                            <button class="btn btn-warning" @onclick="HandleUpdate">Değişiklikleri Kaydet</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private UpdateProjectDto updateProject;

    protected override async Task OnInitializedAsync()
    {
        // Sayfa açıldığında URL'den gelen ID ile mevcut projeyi çekiyoruz
        var existingProject = await ProjectService.GetProjectByIdAsync(Id);

        if (existingProject != null)
        {
            // Gelen veriyi güncelleme modelimize aktarıyoruz
            updateProject = new UpdateProjectDto
            {
                Id = existingProject.Id,
                Name = existingProject.Name,
                Summary = existingProject.Summary,
                TechnicalDetail = existingProject.TechnicalDetail,
                Tags = existingProject.Tags
            };
        }
    }

    private async Task HandleUpdate()
    {
        var isSuccess = await ProjectService.UpdateProjectAsync(updateProject);
        if (isSuccess)
        {
            NavigationManager.NavigateTo("/admin/projects");
        }
    }
}