@page "/admin/skills"
@attribute [Authorize]
@using Portfolio.UI.Models
@using Portfolio.UI.Services
@inject SkillService SkillService
@inject NavigationManager NavigationManager

<div class="container py-5">
    <!-- Header Section -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-5">
        <div>
            <div class="d-flex align-items-center gap-2 mb-2">
                <button class="btn btn-sm btn-outline-secondary border-0 p-1" @onclick='() => NavigationManager.NavigateTo("/admin")'>
                    <i class="bi bi-arrow-left fs-4"></i>
                </button>
                <h2 class="fw-bold text-dark mb-0">Yetenekler Yönetimi</h2>
            </div>
            <p class="text-secondary mb-0 small">Portfolyonuzdaki yetenekleri ve kategorileri buradan düzenleyebilirsiniz.</p>
        </div>
        <button class="btn btn-primary py-2 px-4 fw-bold rounded-3 shadow-sm d-flex align-items-center justify-content-center gap-2 hover-scale" @onclick='() => NavigationManager.NavigateTo("/admin/skills/add")'>
            <i class="bi bi-plus-circle"></i> Yeni Yetenek Ekle
        </button>
    </div>

    <!-- Table Section -->
    <div class="glass-panel p-4 shadow-lg border-0 rounded-4 bg-white">
        @if (skills == null)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                    <span class="visually-hidden">Yükleniyor...</span>
                </div>
                <div class="mt-3 text-secondary">Yetenekler yükleniyor...</div>
            </div>
        }
        else if (!skills.Any())
        {
            <div class="text-center py-5">
                <div class="d-inline-flex p-4 rounded-circle bg-light mb-3">
                    <i class="bi bi-lightning-charge fs-1 text-secondary"></i>
                </div>
                <h4 class="fw-bold text-dark">Henüz Yetenek Eklenmemiş</h4>
                <p class="text-secondary small mb-4">Portfolyonuzda uzmanlık alanlarınızı göstermek için ilk yeteneğinizi ekleyin.</p>
                <button class="btn btn-outline-primary px-4" @onclick='() => NavigationManager.NavigateTo("/admin/skills/add")'>
                    Yeni Yetenek Ekle
                </button>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr class="text-uppercase small tracking-wider text-secondary" style="border-bottom: 2px solid #f1f5f9;">
                            <th class="py-3 px-4 fw-bold" style="width: 45%;">Yetenek Adı</th>
                            <th class="py-3 px-4 fw-bold" style="width: 35%;">Kategori</th>
                            <th class="py-3 px-4 fw-bold text-end" style="width: 20%;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var skill in skills)
                        {
                            <tr style="border-bottom: 1px solid #f1f5f9; transition: background-color 0.2s ease;">
                                <td class="py-3 px-4">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="p-2 rounded bg-light text-primary">
                                            <i class="bi bi-braces"></i>
                                        </div>
                                        <span class="fw-bold text-dark">@skill.Name</span>
                                    </div>
                                </td>
                                <td class="py-3 px-4">
                                    <span class="badge px-3 py-2 rounded-pill fw-medium" style="@GetCategoryBadgeStyle(skill.Category)">
                                        @skill.Category
                                    </span>
                                </td>
                                <td class="py-3 px-4 text-end">
                                    <div class="d-inline-flex gap-2">
                                        <button class="btn btn-sm btn-light border p-2 rounded-3 hover-scale text-warning" @onclick='() => NavigationManager.NavigateTo($"/admin/skills/edit/{skill.Id}")' title="Düzenle">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                        <button class="btn btn-sm btn-light border p-2 rounded-3 hover-scale text-danger" @onclick="() => DeleteSkill(skill.Id)" title="Sil">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private List<SkillDto> skills;

    protected override async Task OnInitializedAsync()
    {
        await LoadSkills();
    }

    private async Task LoadSkills()
    {
        skills = await SkillService.GetAllSkillsAsync();
    }

    private async Task DeleteSkill(int id)
    {
        var isSuccess = await SkillService.DeleteSkillAsync(id);
        if (isSuccess)
        {
            await LoadSkills();
        }
    }

    private string GetCategoryBadgeStyle(string category)
    {
        return category switch
        {
            "Programlama Dilleri" => "background-color: rgba(14, 165, 233, 0.1); color: #0ea5e9;",
            "Frameworkler & Kütüphaneler" => "background-color: rgba(139, 92, 246, 0.1); color: #8b5cf6;",
            "Backend Geliştirme" => "background-color: rgba(16, 185, 129, 0.1); color: #10b981;",
            "Frontend Geliştirme" => "background-color: rgba(245, 158, 11, 0.1); color: #f59e0b;",
            "Mobil Geliştirme" => "background-color: rgba(236, 72, 153, 0.1); color: #ec4899;",
            "Veritabanı" => "background-color: rgba(100, 116, 139, 0.1); color: #64748b;",
            "DevOps & Araçlar" => "background-color: rgba(6, 182, 212, 0.1); color: #06b6d4;",
            "Tasarım & 3D Modelleme" => "background-color: rgba(99, 102, 241, 0.1); color: #6366f1;",
            _ => "background-color: rgba(71, 85, 105, 0.1); color: #475569;"
        };
    }
}
