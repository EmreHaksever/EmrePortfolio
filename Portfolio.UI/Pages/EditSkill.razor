@page "/admin/skills/edit/{Id:int}"
@attribute [Authorize]
@using Portfolio.UI.Models
@using Portfolio.UI.Services
@inject SkillService SkillService
@inject NavigationManager NavigationManager

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-warning">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">Yetenek Düzenle</h4>
                </div>
                <div class="card-body">
                    @if (updateSkill == null)
                    {
                        <p><em>Yükleniyor...</em></p>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label class="form-label">Yetenek Adı</label>
                            <input type="text" class="form-control" @bind="updateSkill.Name" />
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Kategori</label>
                            <select class="form-select" @bind="updateSkill.Category">
                                <option value="">Seçiniz...</option>
                                <option value="Backend">Backend / Sunucu</option>
                                <option value="Frontend">Frontend / Arayüz</option>
                                <option value="Mobile">Mobil Geliştirme</option>
                                <option value="Database">Veritabanı</option>
                                <option value="Design">Tasarım / 3D İmalat</option>
                                <option value="Other">Diğer</option>
                            </select>
                            <div class="form-text text-muted">Yeteneğinizi uygun bir kategoriye atayın.</div>
                        </div>

                     

                        <div class="d-flex justify-content-between">
                            <button class="btn btn-secondary" @onclick="GoBack">İptal</button>
                            <button class="btn btn-warning" @onclick="HandleUpdate">Değişiklikleri Kaydet</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private UpdateSkillDto updateSkill;

    protected override async Task OnInitializedAsync()
    {
        var existingSkill = await SkillService.GetSkillByIdAsync(Id);

        if (existingSkill != null)
        {
            updateSkill = new UpdateSkillDto
            {
                Id = existingSkill.Id,
                Name = existingSkill.Name
             
            };
        }
    }

    private async Task HandleUpdate()
    {
        var isSuccess = await SkillService.UpdateSkillAsync(updateSkill);
        if (isSuccess)
        {
            NavigationManager.NavigateTo("/admin/skills");
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/admin/skills");
    }
}