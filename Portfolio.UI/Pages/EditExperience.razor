@page "/admin/experiences/edit/{Id:int}"
@attribute [Authorize]
@using Portfolio.UI.Models
@using Portfolio.UI.Services
@inject ExperienceService ExperienceService
@inject NavigationManager NavigationManager

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-warning">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">Deneyim Düzenle</h4>
                </div>
                <div class="card-body">
                    @if (updateExperience == null)
                    {
                        <p><em>Yükleniyor...</em></p>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label class="form-label">Pozisyon / Ünvan</label>
                            <input type="text" class="form-control" @bind="updateExperience.Title" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Şirket / Kurum</label>
                            <input type="text" class="form-control" @bind="updateExperience.Company" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Konum</label>
                            <input type="text" class="form-control" @bind="updateExperience.Location" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Açıklama</label>
                            <textarea class="form-control" rows="4" @bind="updateExperience.Description"></textarea>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Başlangıç Tarihi</label>
                                <input type="date" class="form-control" @bind="updateExperience.StartDate" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Bitiş Tarihi</label>
                                <input type="date" class="form-control" @bind="updateExperience.EndDate" disabled="@updateExperience.IsCurrent" />
                            </div>
                        </div>

                        <div class="form-check mb-4">
                            <input class="form-check-input" type="checkbox" id="isCurrentCheck" @bind="updateExperience.IsCurrent">
                            <label class="form-check-label" for="isCurrentCheck">
                                Bu pozisyonda hala çalışıyorum
                            </label>
                        </div>

                        <div class="d-flex justify-content-between">
                            <button class="btn btn-secondary" @onclick="GoBack">İptal</button>
                            <button class="btn btn-warning" @onclick="HandleUpdate">Değişiklikleri Kaydet</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private UpdateExperienceDto updateExperience;

    protected override async Task OnInitializedAsync()
    {
        var existingExperience = await ExperienceService.GetExperienceByIdAsync(Id);

        if (existingExperience != null)
        {
            updateExperience = new UpdateExperienceDto
            {
                Id = existingExperience.Id,
                Title = existingExperience.Title,
                Company = existingExperience.Company,
                Location = existingExperience.Location,
                Description = existingExperience.Description,
                StartDate = existingExperience.StartDate,
                EndDate = existingExperience.EndDate,
                IsCurrent = existingExperience.IsCurrent
            };
        }
    }

    private async Task HandleUpdate()
    {
        if (updateExperience.IsCurrent)
        {
            updateExperience.EndDate = null;
        }

        var isSuccess = await ExperienceService.UpdateExperienceAsync(updateExperience);
        if (isSuccess)
        {
            NavigationManager.NavigateTo("/admin/experiences");
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/admin/experiences");
    }
}