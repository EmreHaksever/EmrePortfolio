@page "/admin/projects"
@attribute [Authorize]
@using Portfolio.UI.Models
@using Portfolio.UI.Services
@inject ProjectService ProjectService

<div class="container mt-4">
    <h3>Projeler Yönetimi</h3>
    <hr />

    @if (projects == null)
    {
        <p><em>Projeler yükleniyor...</em></p>
    }
    else if (!projects.Any())
    {
        <p>Henüz hiç proje eklenmemiş.</p>
    }
    else
    {
        <table class="table table-striped table-hover mt-3">
            <thead class="table-dark">
                <tr>
                    <th>Proje Adı</th>
                    <th>Özet</th>
                    <th>Etiketler</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var project in projects)
                {
                    <tr>
                        <td>@project.Name</td>
                        <td>@project.Summary</td>
                        <td>@project.Tags</td>
                        <td>
                            <button class="btn btn-sm btn-warning">Düzenle</button>
                            <button class="btn btn-sm btn-danger">Sil</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<ProjectDto> projects;

    protected override async Task OnInitializedAsync()
    {
        // Sayfa açılır açılmaz projeleri API'den çek
        projects = await ProjectService.GetAllProjectsAsync();
    }
}