@page "/admin/projects"
@attribute [Authorize]
@using Portfolio.UI.Models
@using Portfolio.UI.Services
@inject ProjectService ProjectService
@inject NavigationManager NavigationManager

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Projeler Yönetimi</h3>
        <button class="btn btn-success" @onclick='() => NavigationManager.NavigateTo("/admin/projects/add")'>
            + Yeni Proje Ekle
        </button>
    </div>
    <hr />

    @if (projects == null)
    {
        <p><em>Projeler yükleniyor...</em></p>
    }
    else if (!projects.Any())
    {
        <div class="alert alert-info">Henüz hiç proje eklenmemiţ.</div>
    }
    else
    {
        <table class="table table-striped table-hover mt-3 shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Proje Adý</th>
                    <th>Özet</th>
                    <th>Etiketler</th>
                    <th>Ýţlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var project in projects)
                {
                    <tr>
                        <td><strong>@project.Name</strong></td>
                        <td>@project.Summary</td>
                        <td><span class="badge bg-secondary">@project.Tags</span></td>
                        <td>
                            <button class="btn btn-sm btn-warning" @onclick='() => NavigationManager.NavigateTo($"/admin/projects/edit/{project.Id}")'>Düzenle</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteProject(project.Id)">Sil</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<ProjectDto> projects;

    protected override async Task OnInitializedAsync()
    {
        await LoadProjects();
    }

    private async Task LoadProjects()
    {
        projects = await ProjectService.GetAllProjectsAsync();
    }

    private async Task DeleteProject(int id)
    {
        // Gerçek bir projede buraya "Emin misiniz?" pop-up'ý konur ama ţimdilik direkt siliyoruz :)
        var isSuccess = await ProjectService.DeleteProjectAsync(id);
        if (isSuccess)
        {
            // Silme baţarýlýysa listeyi yenile
            await LoadProjects();
        }
    }
}
