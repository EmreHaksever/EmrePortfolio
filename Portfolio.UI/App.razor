<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    @if (context.User.Identity?.IsAuthenticated != true)
                    {
                        <div class="alert alert-danger m-5 text-center">
                            Bu sayfayı görüntülemek için <a href="/login">giriş yapmalısınız</a>.
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning m-5 text-center">
                            Bu sayfayı görüntülemek için yetkiniz yok.
                        </div>
                    }
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Bulunamadı</PageTitle>
            <LayoutView Layout="@typeof(MainLayout)">
                <p role="alert">Üzgünüm, böyle bir adres yok.</p>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>